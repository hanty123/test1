// -----------------------------------------------------------------------------------------
// MIRROR & FLIP
// -----------------------------------------------------------------------------------------

BYTE gbMir = 0, gbFlp = 0;
BYTE gbMirFlp = 0;

// VSPI, HSPI
void Sens(SENS_MIRw)(BYTE abOn){
	gbMir = !abOn; 
}

void Sens(SENS_FLPw)(BYTE abOn){
	gbFlp = abOn;	
	gbMirFlp = ((gbFlp<<1)|(gbMir));

	if(gbModeWdrOn_L){
		ICSELw(gbMirFlp);
		DFS_RBG_SELw(!(gbFlp^gbMir));
		DNR_CSELw((gbMir)?(0x3):(0x0));
	}
	else{
		ICSELw(((gbFlp<<1)|(!gbMir)));
		DFS_RBG_SELw(gbFlp^gbMir);
		DNR_CSELw((!gbMir)?(0x3):(0x0));
	}
	
	WDR_CSELw(0x0);
	DNR_RCSELw(0x0);
	
	SetSens(0xfd, 0x1); // Page 1	
	SetSens(0x3f, ((GetSens(0x3f)&(~ValSft_L00(BitMask_03)))|ValSft_L00((gbMirFlp)&BitMask_03)));	
	SetSens(0x01, 0x1); // Mirror, Flip, Gain, Shutter Update Enable	
}