void LibRdesIsp(int aiResMode, int aiWdrMode)
{	
	UNUSED_ARG(aiResMode);
	
	// MIPI RX Configuration
	LibISPtoSENS_Intf(\
		/* MIPI or LVDS */\
		(MIPI),\
		/* 1, 2, 4 LANE */\
		(_2LANE),\
		/* 12BIT(Nor) or 10BIT(WDR) */\
		(aiWdrMode == MN_OFF) ? (_12BIT) : (_10BIT),\
		/* 3210, 10, 0 */\
		(_10),\
		/* Word Count */\
		(aiWdrMode == MN_OFF) ? (0xb4c) : (0x96a),\
		/* MIPI Line information or Virtual channel mode */\
		(_MIPI_VC),\
		(aiWdrMode));
}

void LibInitSens(int aiMode, int aiOption)
{	// OS02H10, Sensor Master mode
	// aiMode   - 0 : Normal 30p, 1 : normal 60p
	// aiOption - 0 : OFF, 1 : DOL 2P
	
	UINT i;

	// ISP - LVDS / MIPI Set
	LibRdesIsp(aiMode, aiOption);

	// Sensor - H/W Reset
	GpioSetLo(GPIO_SRSTN);	WaitUs(10000);		GpioSetHi(GPIO_SRSTN);	WaitUs(10000);

	for(i=0; i<10; i++) {
		if(i2c_write(SENS_OMNI_DEV,1,0) == 0) {
			gbSensorOff = 0;
			TxStrNoIRQ("SI2C connected.", 0, 0);
			break;
		}
		WaitUs(1000);
	}
	if(gbSensorOff) TxStrNoIRQ("SI2C not connected.", 0, 0);

	// Shutter Speed Max
	gnAeNorMax = gnInModeVtw-AE_SHTMAX_OFST;
	
//	Table Address :						0		1		2		3		4		5
//	const WORD gwTblSens0[][6] = 	  //adr 	25p	 	30p	 	50p	 	60p		27.5p
//	const WORD gwTblSens0_LWDR[][4] = //ADDR	25p		30p		27.5p

	// Table Mapping
	switch(aiMode)
	{
		case 0: // 25p, 30p
//			aiMode = MODE_SYSFREQ(2, 1); // (60Hz ? A : B)
			aiMode = (aiOption ? 3 : 5); // (60Hz ? A : B)
		break;
		case 1: // 50p, 60p
			aiMode = MODE_SYSFREQ(4, 3); // (60Hz ? A : B)
		break;
		case 3: // 29.1p, 27.5p
		case 4:
			aiMode = (aiOption ? 3 : 5);
		break;
	};
	
	// Sensor - Adapt Initial Table
	if(aiOption) // WDR
	{
		for (i=0; i<gTblSensEa_LWDR; i++)	{SetSens(gwTblSens0_LWDR[i][0], (BYTE)gwTblSens0_LWDR[i][aiMode]);}

		// L-S Distance(ReadOut)
		SetSens(0xfd, 0x1);
		SetSens(0xd8, 0x0);
		SetSens(0xd9, 0x13); // Max 18 Line
		
		if (aiOption==1) {			// DOL 2P
			gnAeLWdrMaxL0	= 1090/*1125 - 17 - S_MAX = 1108 - S_MAX*/;
			gnAeLWdrMaxS1	= 18  /*Page1, 0xd8, 0xd9*/;
	
			gnAeLWdrMinL0	= 1;//(AE_LWDR_2P_L0_MIN - AE_LWDR_2P_RHS1)-AE_LWDR_2P_L0MIN_OFST;
			gnAeLWdrMinS1	= 1;//(AE_LWDR_2P_S1_MIN)-AE_LWDR_2P_S1MIN_OFST;
		}		
		TxStrNoIRQ("HDR Mode : ", aiMode, 2);
	}
	else // Normal
	{
		for (i=0; i<gTblSensEa; i++)	{SetSens(gwTblSens0[i][0], (BYTE)gwTblSens0[i][aiMode]);}
		TxStrNoIRQ("Nor Mode : ", aiMode, 2);
	}

	WaitUs(1000); // delay for stabilize
}

void ISPM Sens(AE_SHTLw)(UINT val)
{
	SetSens(0xfd, 0x1);	// Page 1
	SetSens(0x03, (val>>8) & 0xff);
	SetSens(0x04, (val & 0xff));
	SetSens(0x1,   0x1); // Mirror, Flip, Gain, Shutter Update Enable
}

void ISPM Sens(AE_SHTSw)(UINT val)
{
	SetSens(0xfd, 0x1); // Page 1
	SetSens(0x4c, (val>>8) & 0xff);
	SetSens(0x4d, (val & 0xff));
	SetSens(0x1,   0x1); // Mirror, Flip, Gain, Shutter Update Enable
}

// Normal AGC 
void ISPM Sens(AE_AGCw)(UINT val)
{	
	static UINT dgcb, b_dgcb_L, b_dgcb_S; // ISP Gain

	// Sensor Gain
	SetSens(0xfd, 0x1); // Page 1	
	
	dgcb = MAX(0x100, (0x100 + (gbAeGainTbl[val][2]*3)));
	
	SetSens(0x24, ((gbAeGainTbl[val][0]<<4) | gbAeGainTbl[val][1]) ); // Long Sensor N[7:4] | Sensor F[3:0]
	SetIsp(0x138, ((b_dgcb_L<<16) | b_dgcb_L));
	SetIsp(0x139, ((b_dgcb_L<<16) | b_dgcb_L));
	b_dgcb_L = dgcb; // Delay 1 Frame
	
	if(gbModeWdrOn_L){
	SetSens(0x45, ((gbAeGainTbl[val][0]<<4) | gbAeGainTbl[val][1])); // Sensor N[7:4] | // Sensor F[3:0]
	SetIsp(0x13a, ((b_dgcb_S<<16) | b_dgcb_S));
	SetIsp(0x13b, ((b_dgcb_S<<16) | b_dgcb_S));
	b_dgcb_S = dgcb; // Delay 1 Frame
	}
	
	SetSens(0x1,   0x1); // Mirror, Flip, Gain, Shutter Update Enable
}

void ISPM Sens(AE_DGCw)(UINT val)
{
	static UINT DGain_N = 0, DGain_F = 0;
	
	// Sensor DGC
	SetSens(0xfd, 0x1); // Page 1
	DGain_N = gbAeGainTbl_Dgc[val][0]; // 5bit
	DGain_F = gbAeGainTbl_Dgc[val][1]; // 6bit
	
	// Long
	SetSens(0xcd, ((DGain_N<<6)|DGain_F) & 0xff); //[7:0] - Long Digital Gain LSB [7:0] - 1x ~ 32x [Calc : (Val/64)]
	SetSens(0xcf, ((DGain_N<<2) & 0x70)); //[6:4] - Long Digital Gain MSB [10:8]
	
	if(gbModeWdrOn_L){
	SetSens(0xce, ((DGain_N<<6)|DGain_F) & 0xff); //[7:0] - Short Digital Gain LSB [7:0] - 1x ~ 32x [Calc : (Val/64)]
	DGain_N = (DGain_N>>2);
	DGain_N = ((DGain_N<<4)|(DGain_N));
	SetSens(0xcf, DGain_N & 0xFF); //[6:4] - Long Digital Gain MSB [10:8]
	}

	SetSens(0x1,   0x1); // Mirror, Flip, Gain, Shutter Update Enable
}

void ISPM Sens(AE_FREQw)(UINT val, UINT val1)
{
	UNUSED_ARG(val); // VMAX
	UNUSED_ARG(val1);// HMAX
	#if(0)
	UINT nHTotal = 0, nVTotal = 0;
	SetSens(0xfd, 0x1); // Select Page 1

	//Horizontal Total (Read Only)
	nHTotal = ((GetSens(0xda)<<8) | (GetSens(0xdb)));
	TxStrNoIRQ("nHTotal : ",nHTotal, 4);
	//Vertical Total (Read Only)
	nVTotal = ((GetSens(0x4e)<<8) | (GetSens(0x4f)));
	TxStrNoIRQ("nVTotal : ",nVTotal, 4);
	#endif
}

//----------------------------------------------------------------------------------------

UINT ISPM LibAeShtLine(UINT anLine)	// Fixed
{
	UINT i;
	UINT nShtDb = 0;
	const UINT nShtLine = anLine * 0x80;

	for(i=1; i<AE_SHT_TBL_EA; i++) {
		if (nShtLine<gnAeShtTbl[i][1]) {
			nShtDb = LibUtlInterp1D (nShtLine, gnAeShtTbl[i-1][1], gnAeShtTbl[i][1], gnAeShtTbl[i-1][0], gnAeShtTbl[i][0]);
			break;
		}
	}
	return nShtDb;
}

void ISPM LibAeShtIntp(int aiVal, const UINT anTblEa, const UINT anFltEa, UINT* apnShtFlt, UINT* apnShtInt)	// Fixed
{
 	UINT	nShtFlt=0;
	UINT	nShtInt=0;
	UINT 	i;
									
	for(i=1; i<anTblEa; i++) {
		if (aiVal<(int)gnAeShtTbl[i][0]) {
			nShtFlt = LibUtlInterp1D (aiVal, gnAeShtTbl[i-1][0], gnAeShtTbl[i][0], gnAeShtTbl[i-1][1], gnAeShtTbl[i][1]);
			nShtInt = nShtFlt>>7;

			if (nShtInt<anFltEa)		nShtFlt = LibUtlInterp1D (nShtFlt, (nShtInt<<7), (nShtInt<<7)+0x80, 0, gbAeHssFltTbl[nShtInt]);
			else 						nShtFlt = 0;
			
			break;
		}
	}
	*apnShtFlt = nShtFlt;
	*apnShtInt = nShtInt;
}

WORD ISPM AeSHT(int aiVal, UINT anManual, UINT anManualVal)
{	// Shutter driver
//** Sensor Spec : Shutter 1 to 1110(VMAX - 15)
	UINT	nMok = gnInModeVtw;
	UINT	nRem = 0;
	UINT	nShtMax = 0;
	static 	UINT	gnShtFlt = 0;
	UINT	nShtInt = 0;

	if (gnAeState==0){ // High Shutter - Only ISP Gain
		AE_AGCw(0x0);
		AE_DGCw(0x0);
		LibAePrgain_L(LibAePrgainIntp(gnShtFlt));
	}
	
	LibAeShtIntp (aiVal, AE_SHT_TBL_EA, AE_HSS_FLT_EA, &gnShtFlt, &nShtInt);

	if(anManual){	// Shutter : Manual
	  nMok 	= (UINT)(MAX(((int)anManualVal - AE_SHTMAX_OFST), (int)0))/gnInModeVtw;
	  nMok 	= ((nMok*gnInModeVtw)+gnInModeVtw);

	  nShtMax = AE_SHTMAX;
	  nRem = MINMAX(anManualVal, AE_SHTMIN_OFST, nShtMax);
	}	
	else { // Shutter : Auto
	  nMok 	= gnInModeVtw; // 1125
	  nShtMax = AE_SHTMAX; // 15
	  nRem 	= MINMAX(nShtInt, AE_SHTMIN_OFST, nShtMax); // 1 ~ 1110
	}

	AE_SHTLw(nRem);

	DebugDisp(gbAeDebugOn, Dec, "SHT_int__d", 1, 24, nRem		)
	DebugDisp(gbAeDebugOn, Dec, "SHT_flt__d", 2, 24, gnShtFlt	)
	
	return ((WORD)(nRem));
}

void ISPM AeAGC(int aiVal)
{	// AGC driver
   	static int	giAgc;
	const UINT nAGC_LMT = AE_GAIN_DENORMAL(AE_SENS_AGC_LMT_NOR);
	static UINT nLWdrGain;
	static UINT nDgc;

	giAgc = AE_GAIN_DENORMAL(aiVal);
	giAgc = MINMAX(giAgc, 0, (AE_GAIN_UNIT_MAX*AE_GAIN_UNIT_EA)+AE_GAIN_UNIT_OVR);

	// WDR GAIN
	if(giAgc <= (int)nAGC_LMT){
		giAeLWdrGain = 0x0;
	}
	else
	{ 
		LibAeGainIntp((aiVal-nAGC_LMT), &nLWdrGain);			//Calculation 0.1dB
		giAeLWdrGain = (int)nLWdrGain;
	}
	
	// AGC, DGC
	if(giAgc >= AE_GAIN_UNIT_MAX) // Sensor AGC
	{
		nDgc = giAgc - AE_GAIN_UNIT_MAX;
		giAgc = (AE_GAIN_UNIT_MAX-1);
	}
	else
	{
		nDgc = 0;
	}

	// Adapt Gain
	if (gnAeState!=0)	{
		AE_AGCw(giAgc);
		AE_DGCw(MAX(nDgc, 0));
	}

	DebugDisp(gbAeDebugOn, Hex, "AGC_____", 5, 24, giAgc )
	DebugDisp(gbAeDebugOn, Hex, "DGC_____", 6, 24, nDgc )
	DebugDisp(gbAeDebugOn, Hex, "WDR_GAIN", 7, 24, giAeLWdrGain)
}


// -------------------------------------------------------------------------------------
// LINE WDR
WORD ISPM AeSHT_LWDR(int aiMode, int aiVal, int aiVal1)
{	// Shutter driver for Line WDR
	// aiMode : 0 : off, 1: 2 page
	// aiVal  : Long
	// aiVal1 : short1
	UNUSED_ARG(aiMode);

	static	UINT	gnShtFlt_L, gnShtFlt_S = 0;
	UINT	nShtInt;
	int tgt_L ;
	int tgt_S1;

	if (gnAeState==0){
		AE_AGCw(0x0);
		LibAePrgain_L(MAX(gnAgc_L, 0x100));
		LibAePrgain_S(MAX(gnAgc_S1, 0x100));
	}

	// - Calc Flt, Shutter
	// Long 
	LibAeShtIntp (aiVal, AE_SHT_TBL_EA, AE_HSS_FLT_EA, &gnShtFlt_L, &nShtInt); // Flt_Agc
	tgt_L = (int)nShtInt;
	gnSht_L		= tgt_L;	// Long   Exposure Shutter line
	gnAgc_L = LibAePrgainIntp(gnShtFlt_L); // L_Flt_Table

	//Short
	LibAeShtIntp (aiVal1, AE_SHT_TBL_EA, AE_HSS_FLT_EA, &gnShtFlt_S, &nShtInt);	
	tgt_S1 = (int)nShtInt;
	gnSht_S1	= tgt_S1;   // Short1 Exposure Shutter line	
	gnAgc_S1 = LibAePrgainIntp(gnShtFlt_S); // S1_Flt_Table
	

	// Adapt L, S Shutter
	AE_SHTLw(tgt_L );
	AE_SHTSw(tgt_S1);

	if (PAR0F==0x3530) {
		DebugDisp(gbAeDebugOn, Dec, "SHT0___d", 0, 24, tgt_L  	)
		DebugDisp(gbAeDebugOn, Dec, "SHT1___d", 1, 24, tgt_S1 	)
	} else {
		DebugDisp(gbAeDebugOn, Dec, "SHT0___d", 0, 24, gnSht_L 	)
		DebugDisp(gbAeDebugOn, Dec, "SHT1___d", 1, 24, gnSht_S1	)
	}

	DebugDisp(gbAeDebugOn, Dec, "SHT_fltL_d", 2, 24, gnShtFlt_L	)
	DebugDisp(gbAeDebugOn, Dec, "SHT_fltL_d", 3, 24, gnShtFlt_S	)
	
	return (0);		// LH TMP
	
}

void ISPM AeAGC_LWDR(int aiMode, int aiVal, int aiVal1)
{
	// AGC driver for Line WDR
	// aiMode : 0: off, 1: 2 page
	// aiVal : Long
	// aiVal1 : short1
	
	UNUSED_ARG(aiMode);
	UNUSED_ARG(aiVal1);

//	status = GetSens(0x3e);
	//N[8], N[7:4], F[3:0], ISP_Gain(0.1dB*n)          dB
	//{0,	1 ,	0  , 0},	// 0
//	status = ((status & ~0x10) | (gbAeGainTbl[val][0]<<4)); // x2 bit
//	SetSens(0x3e, status); // Sensor N[8] = 0xaa = x10.625, (Gain X2 = x)

	static int	giAgcL, giAgcS1;
	static int  iChk;
	static UINT nLWdrGain;
	static UINT nDgc;

	const UINT nLWDR_AGC_LMT = AE_GAIN_DENORMAL(AE_SENS_AGC_LMT_WDR);

	// Calc Gain
	// WDR GAIN
#if(0)
	if(giAgcL <= (int)nLWDR_AGC_LMT){												//AGC+HCG
		giAeLWdrGain = 0x0;
	}
	else{
		LibAeGainIntp((aiVal-AE_SENS_AGC_LMT_WDR), &nLWdrGain); 					//Calculation 0.1dB
		giAeLWdrGain = (int)nLWdrGain;									
//		giAgcL = (nLWDR_AGC_LMT - AE_GAIN_UNIT_OVR);							//AGC MAX
	}

	// Long
	giAgcL = AE_GAIN_DENORMAL(aiVal);		// 171211 LH
	giAgcL = MINMAX(giAgcL, 0, (AE_GAIN_UNIT_MAX*AE_GAIN_UNIT_EA)+AE_GAIN_UNIT_OVR);

	// AGC, DGC
	if(giAgcL >= AE_GAIN_UNIT_MAX) // Sensor AGC
	{
		nDgc = giAgcL - AE_GAIN_UNIT_MAX;
		giAgcL = (AE_GAIN_UNIT_MAX-1);
	}
	else	nDgc = 0;
#else 

	giAgcL = AE_GAIN_DENORMAL(aiVal);		// 171211 LH
	giAgcL = MINMAX(giAgcL, 0, ((AE_GAIN_UNIT_MAX*AE_GAIN_UNIT_EA)+AE_GAIN_UNIT_OVR+AE_GAIN_UNIT_OVR2));
		
	if(giAgcL <= (int)nLWDR_AGC_LMT){												//AGC+HCG
		
		if ((giAgcL-AE_GAIN_UNIT_OVR2) >= 0) {
			giAgcL = giAgcL - AE_GAIN_UNIT_OVR2;
			iChk = 1;
			
			if(giAgcL >= AE_GAIN_UNIT_MAX) // Sensor AGC
			{
				nDgc = giAgcL - AE_GAIN_UNIT_MAX;
				giAgcL = (AE_GAIN_UNIT_MAX-1);
			}
			else	nDgc = 0;
		}
		else 	iChk = 0;
		
		giAeLWdrGain = 0x0;
	}
	
	else{
		if ((giAgcL-AE_GAIN_UNIT_OVR2) >= 0)		iChk = 1;
			
		LibAeGainIntp((aiVal-AE_SENS_AGC_LMT_WDR), &nLWdrGain);						//Calculation 0.1dB
		giAeLWdrGain = (int)nLWdrGain;									
		giAgcL = (nLWDR_AGC_LMT - AE_GAIN_UNIT_OVR2);							//AGC MAX
	}

	SetSens(0xFD, 0x01);
//	SetSens(0x3E, ((iChk)?(0x3C):(0x30)));
	SetSens(0x3E, 0x3C);
	SetSens(0x01, 0x1); // Gain Update Enable	

#endif

	// Short
	giAgcS1 = giAgcL;
	
	if (gnAeState!=0){
		// Long - 0xcd : [7:6] + 0xcf [6:4] = x31
//		LibAePrgain_L(0x100);
//		LibAePrgain_S(0x100);
		
		AE_AGCw(giAgcL);
		AE_DGCw(MAX(nDgc, 0));
	}
		
	DebugDisp(gbAeDebugOn, Hex, "AGC0____", 5, 24, (iChk<<16)|giAgcL)
	DebugDisp(gbAeDebugOn, Hex, "DGC_____", 6, 24, nDgc )
	DebugDisp(gbAeDebugOn, Hex, "WDR_GAIN", 7, 24, (giAeLWdrGain))
}
